datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────
// STAFF — simple PIN-based auth
// ─────────────────────────────────────────────────────

model Staff {
  id        String   @id @default(cuid())
  name      String   @unique
  pinHash   String   // bcrypt-hashed PIN
  active    Boolean  @default(true)
  role      String   @default("operator") // operator, supervisor, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobEvents   PrintJobEvent[]
  pieceEvents PieceEvent[]
  bedsCreated Bed[]           @relation("BedCreator")
}

// ─────────────────────────────────────────────────────
// PRINT JOBS — one per Shopify line item that needs printing
// ─────────────────────────────────────────────────────

model PrintJob {
  id             String   @id @default(cuid())
  shopifyOrderId String   // e.g. "gid://shopify/Order/12345"
  orderName      String   // "#1042"
  lineItemId     String   // Shopify line item ID
  lineItemKey    String   @unique // for webhook dedupe: `${orderId}-${lineItemId}`
  sku            String
  productHandle  String
  productTitle   String
  variantTitle   String   // e.g. "5x7"
  size           String   // parsed from variant (e.g. "5x7")
  material       String   // extracted from product tags or metafield
  quantity       Int
  properties     Json     // full line item properties from cart hook
  frameCount     Int      @default(1)
  status         String   @default("pending") // pending, in_bed, in_production, done, canceled
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pieces   PrintPiece[]
  bedItems BedItem[]
  events   PrintJobEvent[]

  @@index([status])
  @@index([sku])
  @@index([size, material])
}

model PrintJobEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       PrintJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  staffId   String?
  staff     Staff?   @relation(fields: [staffId], references: [id])
  action    String   // "created", "batched", "reprint_requested", "note", "canceled"
  note      String?
  createdAt DateTime @default(now())

  @@index([jobId])
}

// ─────────────────────────────────────────────────────
// BEDS — groups of jobs printed together (same size + material)
// ─────────────────────────────────────────────────────

model Bed {
  id            String    @id @default(cuid())
  workOrderNum  String    @unique // human-readable "WO-2026-0142"
  label         String    // "5x7 Acrylic Blocks"
  size          String    // "5x7"
  material      String    // "Acrylic Block"
  status        String    @default("open") // open, sent_to_bedster, imposed, printing, printed, canceled
  bedsterUrl    String?   // URL to imposed PDF from Bedster
  manifestUrl   String?   // URL to manifest PDF (with QR)
  createdById   String?
  createdBy     Staff?    @relation("BedCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  sentAt        DateTime?
  imposedAt     DateTime?
  printedAt     DateTime?

  items  BedItem[]
  pieces PrintPiece[]

  @@index([status])
  @@index([size, material])
}

model BedItem {
  id       String   @id @default(cuid())
  bedId    String
  bed      Bed      @relation(fields: [bedId], references: [id], onDelete: Cascade)
  jobId    String
  job      PrintJob @relation(fields: [jobId], references: [id])
  quantity Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([bedId, jobId])
}

// ─────────────────────────────────────────────────────
// PIECES — individual printed items with unique QR codes
// ─────────────────────────────────────────────────────

model PrintPiece {
  id          String   @id @default(cuid())
  qrCode      String   @unique // "PS-A7B2C9D1"
  jobId       String
  job         PrintJob @relation(fields: [jobId], references: [id])
  bedId       String?
  bed         Bed?     @relation(fields: [bedId], references: [id])
  pieceIndex  Int      // 1 of N in the job's quantity
  status      String   @default("printed") // printed, qc_pass, qc_fail, reprinting, packed, shipped
  reprintOf   String?  // qrCode of original piece (if this is a reprint)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events PieceEvent[]

  @@index([status])
  @@index([qrCode])
}

model PieceEvent {
  id        String     @id @default(cuid())
  pieceId   String
  piece     PrintPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  staffId   String?
  staff     Staff?     @relation(fields: [staffId], references: [id])
  action    String     // "printed", "scanned", "qc_pass", "qc_fail", "reprint_requested", "packed", "shipped"
  note      String?
  createdAt DateTime   @default(now())

  @@index([pieceId])
}

// ─────────────────────────────────────────────────────
// SESSION — Remix session storage
// ─────────────────────────────────────────────────────

model Session {
  id        String   @id
  data      String   @db.Text
  expiresAt DateTime

  @@index([expiresAt])
}
