DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
SESSION_SECRET="super-duper-s3cret"
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-signing-secret"
# Shopify Admin API (to enrich material from product tags/metafields)
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ADMIN_TOKEN="shpat_xxx-admin-api-access-token"
SHOPIFY_API_VERSION="2024-10"
# Optional: read material from a product metafield instead of tags
SHOPIFY_MATERIAL_METAFIELD="custom.material"
BEDSTER_API_URL="https://bedster.vercel.app"
BEDSTER_API_KEY="your-bedster-api-key"
BEDSTER_WEBHOOK_SECRET="shared-secret-bedster-sends-back"
# Dev only: shows a "Simulate imposition" button to test the flow without Bedster
ALLOW_SIMULATE_IMPOSITION="false"
# Shared token the local print bridge uses to poll the print queue
PRINT_BRIDGE_TOKEN="a-long-random-token"
